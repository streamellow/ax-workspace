# OpenAI
OPENAI_API_KEY=sk-...

# Tavily (웹 검색)
TAVILY_API_KEY=tvly-...

# JWT
JWT_SECRET_KEY=your-secret-key-here
TOKEN_EXPIRE_MINUTES=1440

# Admin 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# Google OAuth 토큰 경로
TOKEN_PATH=/app/token.json
CREDS_PATH=/app/credentials.json
CALENDAR_TOKEN_PATH=/app/calendar_token.json

# Daum 이메일 (선택)
DAUM_EMAIL=
DAUM_PASSWORD=

# 데이터 경로
SQLITE_PATH=/app/data/data.db
CHROMA_PATH=/app/data/chroma_db
